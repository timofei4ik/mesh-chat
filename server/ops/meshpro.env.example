# Copy this file to /etc/mesh-messenger/meshpro.env and set mode 600.
# Never commit the real values.

# Lava.top is the primary MeshPro payment provider. Create a monthly
# subscription product, then copy the product and offer UUIDs. The webhook key
# is generated by you and entered into both Lava webhook configurations.
MESH_LAVA_API_URL=https://gate.lava.top
MESH_LAVA_API_KEY=PASTE_LAVA_PUBLIC_API_KEY
MESH_LAVA_WEBHOOK_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
MESH_LAVA_PRODUCT_ID=PASTE_LAVA_PRODUCT_UUID
MESH_LAVA_OFFER_ID=PASTE_LAVA_MONTHLY_OFFER_UUID

# Optional YooKassa fallback. Test and production use the same API URL;
# shop credentials determine whether payments are test payments.
MESH_YOOKASSA_SHOP_ID=YOUR_TEST_SHOP_ID
MESH_YOOKASSA_SECRET_KEY=YOUR_TEST_SECRET_KEY
MESH_YOOKASSA_WEBHOOK_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
MESH_YOOKASSA_RETURN_URL=https://meshchat-losa.ru/billing/payment-complete

# Shared MeshPro entitlement.
MESH_MESHPRO_MONTHLY_PRICE=199.00
MESH_MESHPRO_MONTHLY_DAYS=30
MESH_BILLING_HOST=127.0.0.1
MESH_BILLING_PORT=8766
MESH_SUBSCRIPTION_CHECKOUT_URL=https://meshchat-losa.ru/meshpro/
MESH_SUBSCRIPTION_MANAGE_URL=

# AI writing assistant. Any OpenAI-compatible chat completions endpoint works.
# Keep the real key only in /etc/mesh-messenger/meshpro.env.
MESH_AI_API_URL=https://api.openai.com/v1/chat/completions
MESH_AI_API_KEY=PASTE_PROVIDER_API_KEY
MESH_AI_MODEL=PASTE_MODEL_ID
MESH_AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
MESH_AI_TIMEOUT_SECONDS=45
MESH_AI_MAX_INPUT_CHARS=4000
MESH_AI_MAX_IMAGE_BYTES=2097152

# Boosty does not expose a public purchase webhook for this flow. Its official
# Telegram bot maintains a private subscriber group; this bot verifies group
# membership and issues one transferable one-time MeshPro key per paid month.
MESH_BOOSTY_TELEGRAM_BOT_TOKEN=PASTE_BOTFATHER_TOKEN
MESH_BOOSTY_TELEGRAM_GROUP_ID=-100PASTE_PRIVATE_GROUP_ID
# Only this Telegram user can create 1/3/6/12-month gift keys. The user must
# also remain the creator of the subscriber group.
MESH_BOOSTY_TELEGRAM_OWNER_ID=PASTE_CREATOR_TELEGRAM_USER_ID
MESH_BOOSTY_ACTIVATION_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
MESH_BOOSTY_ACTIVATION_URL=https://meshchat-losa.ru/meshpro/activate
# Retained for compatibility with activation codes issued by older servers.
MESH_BOOSTY_CODE_TTL_SECONDS=600
MESH_BOOSTY_KEY_DURATION_DAYS=30
MESH_BOOSTY_KEY_ISSUE_INTERVAL_DAYS=30
MESH_BOOSTY_RECONCILE_SECONDS=21600

# Manual launch through a personal Sber collection. Create the collection in
# SberBank Online and paste its HTTPS share link here. The server creates a
# pending order but never grants MeshPro until an administrator approves it.
MESH_SBER_PAYMENT_URL=https://messenger.online.sberbank.ru/sl/PASTE_LINK

# One WireGuard peer is generated for every MeshPro account/device pair.
MESH_WG_ENABLED=1
MESH_WG_INTERFACE=wg0
MESH_WG_ENDPOINT=meshchat-losa.ru:51820
MESH_WG_NETWORK=10.77.0.0/24
MESH_WG_SERVER_ADDRESS=10.77.0.1
MESH_WG_SERVER_PUBLIC_KEY=PASTE_WG_SERVER_PUBLIC_KEY
MESH_WG_DNS=1.1.1.1,1.0.0.1
MESH_WG_ALLOWED_IPS=0.0.0.0/0,::/0
MESH_WG_PEER_DIR=/var/lib/mesh-messenger/wireguard-peers
MESH_MESHPRIVACY_MIN_APP_VERSION=1.3.0
